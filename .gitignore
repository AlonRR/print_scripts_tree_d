# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
wheels/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Type checking / linting caches
.mypy_cache/
.ruff_cache/

# uv
# uv.lock is intentionally tracked for reproducibility

# VS Code — keep extensions.json and settings.json tracked
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# Generated 3D output files and all sub-folders (keep the .gitkeep placeholder)
models/*
!models/.gitkeep

# Scratch / interactive dev scripts (local only)
scratch/

# OS noise
.DS_Store
Thumbs.db
desktop.ini
